{
  "id": "b03-billing-transaction-count",
  "layer": "b",
  "title": "Count transactions (billing-insights skill)",
  "skill": "zeyos-billing-insights",
  "interface": "either",
  "mutates": false,
  "tags": ["billing-insights", "resource-discovery"],
  "prompt": "Using the billing-insights skill, answer: how many transactions exist in total? Note: the transactions resource has no `visibility` field, so do not filter on it. Output just the number on the RESULT line, e.g. `RESULT: 318`.",
  "expect": {
    "kind": "all",
    "expectations": [
      {
        "kind": "computeCount",
        "op": "listTransactions",
        "params": { "limit": 10000 },
        "predicates": [],
        "match": "exact"
      },
      {
        "kind": "verifyTrace",
        "severity": "efficiency",
        "require": [{ "operation": "listTransactions", "min": 1, "max": 2 }],
        "maxUpstreamRequests": 3,
        "maxApiErrors": 0,
        "maxToolCalls": 5,
        "maxZeyosCliCalls": 2
      }
    ]
  }
}
