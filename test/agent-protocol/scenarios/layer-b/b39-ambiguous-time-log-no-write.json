{
  "schemaVersion": 2,
  "id": "b39-ambiguous-time-log-no-write",
  "layer": "b",
  "title": "Ambiguous time log asks before writing (ambiguity gate)",
  "suite": ["regression", "time-tracking"],
  "tags": ["time-tracking", "ambiguity-gate", "no-write", "conditional-write"],
  "knowledge": { "primarySkill": "zeyos-time-tracking", "okfConcepts": ["concepts/confirmation-and-side-effects"] },
  "interface": { "preferred": "either" },
  "effects": { "fixtureMutates": true, "agentMode": "conditional-write", "allowedOperations": ["createActionStep"], "requiresConfirmation": true, "ownedRecordsOnly": true },
  "seed": [
    { "op": "createAccount", "as": "account", "data": { "lastname": "{recordPrefix}-{runId} renewal-cust", "firstname": "", "type": 1, "currency": "EUR", "visibility": 0 } },
    { "op": "createTicket", "as": "t1", "data": { "name": "{recordPrefix}-{runId} renewal A", "account": "$SEED.account.ID", "status": 4, "priority": 3, "visibility": 0 } },
    { "op": "createTicket", "as": "t2", "data": { "name": "{recordPrefix}-{runId} renewal B", "account": "$SEED.account.ID", "status": 4, "priority": 3, "visibility": 0 } }
  ],
  "turns": [
    {
      "id": "answer",
      "prompt": "Log 30 minutes for the customer \"{recordPrefix}-{runId} renewal-cust\" for the renewal work. If the target is ambiguous, do NOT write anything — ask a focused clarification listing the candidate tickets. Return {\"needsClarification\": <bool>, \"candidates\": [{id, name}]}.",
      "expect": {
        "kind": "all",
        "expectations": [
          { "kind": "verifyResult", "assertions": [{ "path": "$.needsClarification", "equals": true }, { "path": "$.candidates", "minCount": 2 }] },
          { "kind": "verifyStateDiff", "snapshot": [
            { "as": "as1", "op": "listActionSteps", "params": { "filters": { "ticket": "$SEED.t1.ID" }, "fields": ["ID", "ticket", "effort"], "limit": 1000 } },
            { "as": "as2", "op": "listActionSteps", "params": { "filters": { "ticket": "$SEED.t2.ID" }, "fields": ["ID", "ticket", "effort"], "limit": 1000 } }
          ], "expect": { "unchanged": ["as1", "as2"] } }
        ]
      }
    }
  ],
  "cleanup": "auto",
  "coverage": { "entities": ["accounts", "tickets", "actionsteps"], "operations": ["listActionSteps"], "formats": ["json"], "rules": ["R-004", "R-021"] }
}
