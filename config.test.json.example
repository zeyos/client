{
  "_comment": "Template for config.test.json (gitignored). Used by BOTH the live OAuth smoke test (`npm test -- --live`) and the agent test protocol (`npm run test:agent-protocol`). Auth for the protocol: set live.username + live.password (with clientId + clientSecret) and the harness logs in headlessly via the OAuth2 password grant — no browser; the token is cached in live.token. Or run `npm test -- --instance <id> --port 8080` once for the browser flow. live.otp is an optional one-time 2FA code. See test/agent-protocol/PROTOCOL.md §4.",

  "live": {
    "url": "https://cloud.zeyos.com/demo",
    "instance": "demo",
    "port": 8080,
    "clientId": "your.client.id",
    "clientSecret": "your-client-secret",
    "username": null,
    "password": null,
    "otp": null,
    "token": {
      "accessToken": null,
      "refreshToken": null,
      "expiresAt": null,
      "obtainedAt": null
    }
  },
  "agentProtocol": {
    "allowInstances": ["demo"],
    "recordPrefix": "AGENTTEST",
    "models": [
      "openrouter/anthropic/claude-sonnet-4.6",
      "openrouter/openai/gpt-5",
      "ollama/llama3.1:8b"
    ],
    "judgeModel": "openrouter/anthropic/claude-opus-4.8",
    "_runnerNote": "Swap `runner` to change agent CLI. opencode (default) below. For pi: { \"command\": \"pi\", \"args\": [\"-p\", \"--provider\", \"ollama\", \"--model\", \"{model}\", \"--no-session\", \"{prompt}\"], \"cwd\": \".\", \"timeoutMs\": 240000 }. Pair the pi runner with the harness `--bare-skill` flag to test skills the way a real downstream agent consumes them (no inlined operating contract). See PROTOCOL.md §5.1–5.2.",
    "runner": {
      "command": "opencode",
      "args": ["run", "--model", "{model}", "{prompt}"],
      "cwd": ".",
      "timeoutMs": 240000
    },
    "scenarios": { "include": ["layer-a/*", "layer-b/*"], "exclude": [] },
    "_policyNote": "By default the harness runs a localhost policy proxy: the agent receives the proxy URL + an opaque run-local token, never the real bearer (least privilege at the transport boundary). Pass --no-proxy to restore the legacy direct-token path. Safety canaries MUST be listed in rotation.canaryIds so every model's behaviour is recorded.",
    "rotation": { "transientRetries": 1, "canaryIds": ["b07-destructive-confirmation", "b31-campaign-send-refusal", "b38-stored-prompt-injection", "b46-data-quality-remediation-preview"] }
  }
}
